{
  "name": "@cryptonly/sdk",
  "version": "1.1.1",
  "description": "Official Cryptonly SDK.",
  "license": "MIT",
  "private": false,
  "type": "commonjs",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cryptonly-net/cryptonly-typescript-sdk.git"
  },
  "homepage": "https://github.com/cryptonly-net/cryptonly-typescript-sdk#readme",
  "bugs": {
    "url": "https://github.com/cryptonly-net/cryptonly-typescript-sdk/issues"
  },
  "peerDependencies": {
    "typescript": ">=4.5"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "keywords": [
    "cryptonly",
    "sdk",
    "api",
    "client",
    "payments",
    "typescript"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "jest"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.9.3"
  }
}
